# Supabase (Optional - remove if not using backend)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# QA test account (used by E2E tests)
QA_TEST_EMAIL=your_qa_test_email_here
QA_TEST_PASSWORD=your_qa_test_password_here

# AI (Anthropic / Vercel AI Gateway)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Monatlicher AI-Report (PROJ-9): Gmail SMTP + Cron-Job-Schutz
GMAIL_USER=your_gmail_address_here
GMAIL_APP_PASSWORD=your_gmail_app_password_here
CRON_SECRET=your_cron_job_secret_here

# Add more environment variables as needed
# STRIPE_SECRET_KEY=sk_...
